# Зависимости - самое важное!
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Файлы окружения - содержат пароли и секреты
.env
.env.local
.env.production
.env.development
.env.test

# База данных - никогда не коммитим данные!
*.sqlite
*.sqlite3
*.db
*.myd
*.myi
*.frm
*.ibd
*.sdi
mysql-data/
data/

# Дампы базы данных
*.sql
!database/structure.sql
!database/migrations/*.sql
backup.sql
dump.sql
database_dump.sql

# Логи - не нужно хранить в репозитории
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log
*.pid
*.seed
*.pid.lock

# Временные файлы
tmp/
temp/
*.tmp
*.temp
*.cache
*.swp
*.swo
*~

# Системные файлы
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.lnk
.directory

# Файлы IDE - настройки конкретной среды разработки
.vscode/
.idea/
*.sublime-*
.project
.classpath
.settings/
.vs/
*.code-workspace
.history/

# Файлы сгенерированные при запуске
dist/
build/
coverage/
*.tsbuildinfo
.eslintcache

# Docker файлы (если используете)
.docker/
docker-compose.override.yml
*.pid
*.seed
*.pid.lock

# Файлы с приватными ключами
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# Файлы тестов
test/data/
test/temp/
coverage/
.nyc_output/

# Файлы документации
docs/_build/
docs/api/

# Файлы, созданные во время разработки
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

